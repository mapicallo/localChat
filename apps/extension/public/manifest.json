{
  "manifest_version": 3,
  "name": "LocalChat — local AI chat in Chrome",
  "version": "0.3.0",
  "description": "Chat with your browser's built-in AI. Private, on-device, no cloud upload.",
  "action": {
    "default_title": "LocalChat",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["sidePanel", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
